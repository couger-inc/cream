{
  "compilerOptions": {
    "lib": ["ES2018", "DOM"],
    "module": "CommonJs",
    "moduleResolution": "node",
    "strict": true,
    "target": "ES2018",
    "sourceMap": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "types": ["@types/bn.js", "@types/chai", "@types/mocha"],
    "typeRoots": ["./types"]
  },
  "exclude": [
    "./node_modules/@types/jest/index.d.ts"
  ]
}
